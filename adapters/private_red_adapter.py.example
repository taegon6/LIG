from __future__ import annotations

from typing import Any


class PrivateRedAdapterExample:
    """Template for team-local competition wiring.

    This example intentionally contains no remote address, no auth material,
    no offensive routine, and no executable interaction with outside systems.
    Keep real competition wiring outside the public repository.
    Official DAH integration must follow competition rules and remain private.
    """

    configured = False

    def adapter_status(self) -> dict[str, Any]:
        return {
            "configured": False,
            "external_access": False,
            "description": "Team-private Red adapter template; public copy is inert.",
        }

    def observe_official_state(self) -> dict[str, Any]:
        return {
            "configured": False,
            "state_available": False,
            "description": "Public example does not observe an outside runtime.",
        }

    def list_allowed_red_actions(self) -> list[str]:
        return [
            "OBSERVE_TARGET_STATE",
            "SELECT_ALLOWED_TARGET",
            "SUBMIT_ALLOWED_RED_ACTION",
            "REQUEST_SCORE_FEEDBACK",
            "PRESSURE_SLA_TARGET",
            "CONFUSE_DEFENSE_SIGNAL",
            "COVERAGE_PROBE",
        ]

    def plan_allowed_red_action(self, context: dict[str, Any]) -> dict[str, Any]:
        return {
            "red_objective": "COVERAGE",
            "event_type": "LOG_NOISE",
            "intensity": 0.2,
            "strategy_reason": "Public template returns a harmless local simulation choice.",
            "expected_effect": "No outside interaction occurs.",
            "context_keys": sorted(context.keys()),
        }

    def submit_allowed_red_action(self, action: dict[str, Any]) -> dict[str, Any]:
        return {
            "accepted": False,
            "external_access": False,
            "description": "Public example records no outside action.",
            "action_keys": sorted(action.keys()),
        }

    def get_red_feedback(self) -> dict[str, float]:
        return {
            "red_success_score": 0.0,
            "sla_pressure": 0.0,
            "coverage": 0.0,
        }
