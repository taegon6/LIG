from __future__ import annotations

from typing import Any


class PrivateRedAdapterExample:
    """Template for team-local competition wiring.

    This example intentionally contains no remote address, no auth material,
    no offensive routine, and no executable interaction with outside systems.
    Keep real competition wiring outside the public repository.
    """

    configured = False

    def adapter_status(self) -> dict[str, Any]:
        return {
            "configured": False,
            "external_access": False,
            "description": "Team-private Red adapter template; public copy is inert.",
        }

    def choose_safe_objective(self, context: dict[str, Any]) -> dict[str, Any]:
        return {
            "red_objective": "COVERAGE",
            "event_type": "LOG_NOISE",
            "intensity": 0.2,
            "strategy_reason": "Public template returns a harmless local simulation choice.",
            "expected_effect": "No outside interaction occurs.",
            "context_keys": sorted(context.keys()),
        }
